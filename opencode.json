{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "prisma": {
      "type": "local",
      "command": ["npx", "-y", "prisma", "mcp"],
      "enabled": true,
      "timeout": 30000
    },
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "./src"],
      "enabled": true
    }
  }
}
